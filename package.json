{
  "name": "monofly",
  "version": "0.1.6",
  "description": "MonoFly is a made-for-creator design system package that provides a collection of reusable dashboards, components, and styles for building user operating systems. It is a singular codebase monorepository designed to work seamlessly with Figma and create cohesive personal designs for creators.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/guard-no-runtime-deps.mjs",
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.3.10",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-aria-components": "^1.10.1",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffersonkidd/monofly.git"
  },
  "keywords": [
    "npm",
    "vite",
    "react",
    "monorepo",
    "design system package",
    "creator OS",
    "figma"
  ],
  "author": "jeffersonkidd",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jeffersonkidd/monofly/issues"
  },
  "homepage": "https://github.com/jeffersonkidd/monofly#readme"
}
