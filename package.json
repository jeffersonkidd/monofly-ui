{
  "name": "monofly",
  "version": "0.1.3",
  "description": "MonoFly is a made-for-creator design system package that provides a collection of reusable dashboards, components, and styles for building user operating systems. It is a singular codebase monorepository designed to work seamlessly with Figma and create cohesive personal designs for creators.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": ["**/*.css"],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vite": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffersonkidd/monofly.git"
  },
  "keywords": [
    "npm",
    "vite",
    "react",
    "monorepo",
    "design system package",
    "creator OS",
    "figma"
  ],
  "author": "jeffersonkidd",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jeffersonkidd/monofly/issues"
  },
  "homepage": "https://github.com/jeffersonkidd/monofly#readme"
}
